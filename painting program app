<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Easy Paint App</title>
<style>
  :root{
    --bg:#f4f6f8;
    --panel:#ffffff;
    --text:#1f2a37;
    --sub:#4b5563;
    --border:#e5e7eb;
    --accent:#2563eb;
  }
  *{box-sizing:border-box}
  body{
    margin:0;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, "Hiragino Kaku Gothic ProN", Meiryo, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height:1.4;
  }
  header{
    padding:14px 18px;
    background:#0f172a;
    color:#fff;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    flex-wrap:wrap;
  }
  header h1{
    margin:0;
    font-size:18px;
    font-weight:700;
    letter-spacing:.3px;
  }
  header .small{
    font-size:12px;
    opacity:.85;
  }
  main{
    padding:16px;
    display:grid;
    grid-template-columns: 320px 1fr;
    gap:16px;
  }
  @media (max-width: 900px){
    main{
      grid-template-columns: 1fr;
    }
  }
  .panel{
    background: var(--panel);
    border:1px solid var(--border);
    border-radius:12px;
    padding:14px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.05);
  }
  .section-title{
    font-size:14px;
    font-weight:700;
    margin:8px 0 10px 0;
    color:var(--sub);
  }
  .row{
    display:flex;
    gap:10px;
    align-items:center;
    flex-wrap:wrap;
    margin-bottom:10px;
  }
  label{
    font-size:13px;
    color:var(--sub);
    min-width:86px;
  }
  select, input[type="range"], input[type="color"]{
    appearance:none;
    -webkit-appearance:none;
    background:#fff;
    border:1px solid var(--border);
    border-radius:8px;
    padding:8px 10px;
    font-size:14px;
    color:var(--text);
    outline:none;
  }
  input[type="range"]{
    padding:0;
    height:34px;
    width:180px;
  }
  input[type="color"]{
    width:44px;
    height:34px;
    padding:0;
  }
  .chip-group{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
  }
  .chip{
    border:1px solid var(--border);
    background:#fff;
    padding:8px 10px;
    border-radius:20px;
    font-size:13px;
    cursor:pointer;
    user-select:none;
  }
  .chip.active{
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.12) inset;
  }
  .tools{
    display:grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap:8px;
    margin-bottom:8px;
  }
  .btn{
    display:flex;
    align-items:center;
    justify-content:center;
    gap:6px;
    padding:10px 8px;
    border:1px solid var(--border);
    background:#fff;
    border-radius:10px;
    cursor:pointer;
    font-size:13px;
    user-select:none;
  }
  .btn.active{
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.12) inset;
  }
  .btn.wide{ grid-column: span 2; }
  .btn.full{ grid-column: 1 / -1; }
  .color-sample{
    width:16px;height:16px;border-radius:50%;border:1px solid #cbd5e1;display:inline-block;
  }
  .canvas-wrap{
    position:relative;
    background:#ddd;
    border-radius:12px;
    overflow:hidden;
  }
  .paper{
    position:absolute; inset:0; pointer-events:none; mix-blend-mode:multiply; opacity:.28;
    background-size: 600px 600px;
  }
  .topbar{
    display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:10px;
  }
  .spacer{ flex:1 }
  .small-note{
    font-size:12px;color:var(--sub);
  }
  .stroke-preview{
    height:34px; border:1px dashed var(--border); border-radius:8px; background:#fff; display:flex; align-items:center; padding:0 8px; gap:10px;
  }
  .dot{ width:8px; height:8px; border-radius:50%; background:#111 }
  .shape-preview{
    display:flex; gap:6px; align-items:center;
  }
  .hidden{ display:none }
  canvas{
    display:block;
    width:100%;
    height:70vh;
    max-height:75vh;
    background:#fff;
    cursor: crosshair;
  }
  footer{
    padding:10px 16px; font-size:12px; color:var(--sub);
    text-align:center;
  }
</style>
</head>
<body>
<header>
  <h1>Easy Paint App</h1>
  <div class="small">Simple draw tool — かんたんお絵かき</div>
</header>

<main>
  <!-- Left control panel -->
  <section class="panel" aria-label="Controls">
    <div class="section-title">Paper</div>
    <div class="row">
      <label for="paperColor">Paper color</label>
      <div class="chip-group" id="paperColors">
        <div class="chip active" data-paper="#ffffff"><span class="color-sample" style="background:#ffffff"></span> White</div>
        <div class="chip" data-paper="#f8f5e7"><span class="color-sample" style="background:#f8f5e7"></span> Cream</div>
        <div class="chip" data-paper="#f0f9ff"><span class="color-sample" style="background:#f0f9ff"></span> Light Blue</div>
        <div class="chip" data-paper="#fff1f2"><span class="color-sample" style="background:#fff1f2"></span> Light Pink</div>
        <div class="chip" data-paper="#111827"><span class="color-sample" style="background:#111827"></span> Dark</div>
      </div>
    </div>
    <div class="row">
      <label>Paper type</label>
      <div class="chip-group" id="paperType">
        <div class="chip active" data-type="canvas">Canvas pad</div>
        <div class="chip" data-type="watercolor">Watercolor paper</div>
        <div class="chip" data-type="smooth">Smooth</div>
        <div class="chip" data-type="grain">Grain</div>
        <div class="chip" data-type="none">None</div>
      </div>
    </div>

    <hr style="border:none;border-top:1px solid var(--border); margin:12px 0">

    <div class="section-title">Tools</div>
    <div class="tools">
      <div class="btn active" id="toolBrush" data-tool="brush" title="Brush">Brush</div>
      <div class="btn" id="toolMarker" data-tool="marker" title="Marker">Marker</div>
      <div class="btn" id="toolPencil" data-tool="pencil" title="Pencil">Pencil</div>
      <div class="btn" id="toolAir" data-tool="airbrush" title="Airbrush">Air</div>
      <div class="btn" id="toolEraser" data-tool="eraser" title="Eraser">Eraser</div>

      <div class="btn wide" id="toolLine" data-tool="line" title="Line">Line</div>
      <div class="btn wide" id="toolRect" data-tool="rect" title="Rectangle">Rectangle</div>
      <div class="btn wide" id="toolCircle" data-tool="circle" title="Circle">Circle</div>
      <div class="btn wide" id="toolFill" data-tool="fill" title="Fill">Fill</div>

      <div class="btn full" id="btnClear">Clear Paper</div>
      <div class="btn full" id="btnUndo">Undo</div>
      <div class="btn full" id="btnSave">Save as PNG</div>
    </div>

    <div class="section-title">Color and size</div>
    <div class="row">
      <label for="colorPick">Color</label>
      <input id="colorPick" type="color" value="#1f2937" />
      <div class="chip-group" id="swatches">
        <div class="chip active" data-color="#1f2937"><span class="color-sample" style="background:#1f2937"></span></div>
        <div class="chip" data-color="#ef4444"><span class="color-sample" style="background:#ef4444"></span></div>
        <div class="chip" data-color="#f59e0b"><span class="color-sample" style="background:#f59e0b"></span></div>
        <div class="chip" data-color="#10b981"><span class="color-sample" style="background:#10b981"></span></div>
        <div class="chip" data-color="#3b82f6"><span class="color-sample" style="background:#3b82f6"></span></div>
        <div class="chip" data-color="#8b5cf6"><span class="color-sample" style="background:#8b5cf6"></span></div>
      </div>
    </div>
    <div class="row">
      <label for="sizeRange">Size</label>
      <input id="sizeRange" type="range" min="1" max="60" value="10" />
      <div class="stroke-preview" id="strokePreview">
        <div class="dot" id="dotPreview" style="width:10px;height:10px;border-radius:50%;background:#1f2937"></div>
        <span class="small-note" id="sizeLabel">10 px</span>
      </div>
    </div>

    <div class="section-title">Brush type</div>
    <div class="row">
      <label for="brushType">Tip</label>
      <select id="brushType">
        <option value="round" selected>Round</option>
        <option value="square">Square</option>
        <option value="calligraphy">Calligraphy (flat)</option>
        <option value="soft">Soft</option>
        <option value="texture">Texture</option>
      </select>
    </div>
    <div class="row">
      <label for="opacityRange">Opacity</label>
      <input id="opacityRange" type="range" min="0.05" max="1" step="0.05" value="1"/>
      <span class="small-note" id="opacityLabel">100%</span>
    </div>
  </section>

  <!-- Right drawing area -->
  <section class="panel">
    <div class="topbar">
      <div><strong>Draw area</strong></div>
      <div class="spacer"></div>
      <div class="shape-preview small-note">Tip: hold Shift for straight line</div>
    </div>
    <div class="canvas-wrap" id="canvasWrap">
      <canvas id="canvas" width="1400" height="900" aria-label="Drawing canvas"></canvas>
      <div class="paper" id="paperTexture"></div>
    </div>
  </section>
</main>

<footer>
  Use mouse or finger to draw. クリック・ドラッグで描きます。Shiftキーで直線。
</footer>

<script>
  // Simple English guide:
  // - This app lets you draw.
  // - Choose tool, color, size.
  // - Pick paper color and paper type (texture).
  // - You can undo, clear, fill, save.

  const canvas = document.getElementById('canvas');
  const ctx = canvas.getContext('2d', { willReadFrequently: true });
  const wrap = document.getElementById('canvasWrap');
  const paperLayer = document.getElementById('paperTexture');

  // State (current settings)
  const state = {
    tool: 'brush',
    color: '#1f2937',
    size: 10,
    opacity: 1,
    brushTip: 'round',
    isDrawing: false,
    last: null,
    start: null,
    paperColor: '#ffffff',
    paperType: 'canvas',
    history: [],
    maxHistory: 30,
    isShift: false,
  };

  // Fit canvas to CSS size (HiDPI support)
  function resizeCanvasToDisplaySize() {
    const rect = wrap.getBoundingClientRect();
    const ratio = window.devicePixelRatio || 1;
    const desiredWidth = Math.max(600, Math.floor(rect.width));
    const desiredHeight = Math.max(400, Math.floor(rect.height * 0.7));

    if (canvas.width !== Math.floor(desiredWidth * ratio) || canvas.height !== Math.floor(desiredHeight * ratio)) {
      const img = ctx.getImageData(0, 0, canvas.width, canvas.height);
      canvas.width = Math.floor(desiredWidth * ratio);
      canvas.height = Math.floor(desiredHeight * ratio);
      canvas.style.width = desiredWidth + 'px';
      canvas.style.height = desiredHeight + 'px';
      ctx.putImageData(img, 0, 0);
      applyPaperColor(); // repaint bg
      redrawAll();
    }
  }

  window.addEventListener('resize', resizeCanvasToDisplaySize);
  resizeCanvasToDisplaySize();

  // Helper: save and restore for Undo
  function pushHistory() {
    try{
      const img = ctx.getImageData(0, 0, canvas.width, canvas.height);
      state.history.push(img);
      if (state.history.length > state.maxHistory) state.history.shift();
    }catch(e){
      // If out of memory, drop oldest
      if (state.history.length) state.history.shift();
    }
  }
  function undo() {
    if (!state.history.length) return;
    const img = state.history.pop();
    ctx.putImageData(img, 0, 0);
  }
  function redrawAll(){
    // nothing special; the canvas already holds pixels
  }

  // Paper color and texture
  function applyPaperColor() {
    // Fill background with paper color once at bottom layer
    // We draw a full-rect fill below all strokes by compositing a new layer
    const img = ctx.getImageData(0, 0, canvas.width, canvas.height);
    ctx.save();
    ctx.globalCompositeOperation = 'destination-over';
    ctx.fillStyle = state.paperColor;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.restore();
    // keep pixels, no need to re-apply img
  }

  function setPaperType(type){
    state.paperType = type;
    // Create patterns using CSS background for the overlay div
    // Simple generated SVG data URIs for textures
    let bg = '';
    if (type === 'none'){
      paperLayer.style.opacity = '0';
      paperLayer.style.backgroundImage = 'none';
      return;
    }
    paperLayer.style.opacity = '0.28';

    if (type === 'canvas'){
      // subtle cross weave
      bg = `
        radial-gradient(circle at 25% 25%, rgba(0,0,0,0.18) 0 1px, transparent 1px),
        radial-gradient(circle at 75% 75%, rgba(0,0,0,0.18) 0 1px, transparent 1px),
        linear-gradient(0deg, rgba(0,0,0,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,0.08) 1px, transparent 1px)
      `;
      paperLayer.style.backgroundImage = bg;
      paperLayer.style.backgroundSize = '20px 20px, 20px 20px, 10px 10px, 10px 10px';
    } else if (type === 'watercolor'){
      // cloudy watercolor
      bg = `
        radial-gradient(60% 60% at 30% 40%, rgba(0,0,0,0.25), transparent 60%),
        radial-gradient(50% 50% at 70% 60%, rgba(0,0,0,0.2), transparent 60%),
        radial-gradient(40% 40% at 50% 80%, rgba(0,0,0,0.15), transparent 60%)
      `;
      paperLayer.style.backgroundImage = bg;
      paperLayer.style.backgroundSize = '600px 600px';
    } else if (type === 'smooth'){
      // very light noise-like pattern
      bg = `
        radial-gradient(circle at 10% 20%, rgba(0,0,0,0.08) 0 0.5px, transparent 0.6px),
        radial-gradient(circle at 80% 70%, rgba(0,0,0,0.08) 0 0.5px, transparent 0.6px),
        radial-gradient(circle at 40% 50%, rgba(0,0,0,0.08) 0 0.5px, transparent 0.6px)
      `;
      paperLayer.style.backgroundImage = bg;
      paperLayer.style.backgroundSize = '24px 24px';
    } else if (type === 'grain'){
      // dotted grain
      bg = `
        radial-gradient(circle, rgba(0,0,0,0.22) 1px, transparent 1.5px)
      `;
      paperLayer.style.backgroundImage = bg;
      paperLayer.style.backgroundSize = '8px 8px';
    }
  }

  // UI bindings
  const tools = document.querySelectorAll('.btn[data-tool]');
  tools.forEach(b=>{
    b.addEventListener('click', ()=>{
      tools.forEach(x=>x.classList.remove('active'));
      b.classList.add('active');
      state.tool = b.dataset.tool;
    });
  });

  document.getElementById('btnClear').addEventListener('click', ()=>{
    pushHistory();
    ctx.clearRect(0,0,canvas.width,canvas.height);
    applyPaperColor();
  });
  document.getElementById('btnUndo').addEventListener('click', undo);
  document.getElementById('btnSave').addEventListener('click', ()=>{
    // Make a temporary canvas to bake paper color under pixels
    const tmp = document.createElement('canvas');
    tmp.width = canvas.width;
    tmp.height = canvas.height;
    const tctx = tmp.getContext('2d');
    tctx.fillStyle = state.paperColor;
    tctx.fillRect(0,0,tmp.width,tmp.height);
    tctx.drawImage(canvas,0,0);
    const url = tmp.toDataURL('image/png');
    const a = document.createElement('a');
    a.href = url;
    a.download = 'my-drawing.png';
    a.click();
  });

  // Color and size
  const colorPick = document.getElementById('colorPick');
  const swatches = document.getElementById('swatches');
  const sizeRange = document.getElementById('sizeRange');
  const opacityRange = document.getElementById('opacityRange');
  const sizeLabel = document.getElementById('sizeLabel');
  const dotPreview = document.getElementById('dotPreview');
  const opacityLabel = document.getElementById('opacityLabel');

  colorPick.addEventListener('input', e=>{
    state.color = e.target.value;
    swatches.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
    dotPreview.style.background = state.color;
  });
  swatches.querySelectorAll('.chip').forEach(c=>{
    c.addEventListener('click', ()=>{
      swatches.querySelectorAll('.chip').forEach(x=>x.classList.remove('active'));
      c.classList.add('active');
      const col = c.dataset.color;
      if (col){
        state.color = col;
        colorPick.value = col;
        dotPreview.style.background = col;
      }
    });
  });

  sizeRange.addEventListener('input', e=>{
    state.size = parseInt(e.target.value,10);
    sizeLabel.textContent = state.size + ' px';
    dotPreview.style.width = state.size + 'px';
    dotPreview.style.height = state.size + 'px';
  });

  opacityRange.addEventListener('input', e=>{
    state.opacity = parseFloat(e.target.value);
    opacityLabel.textContent = Math.round(state.opacity*100) + '%';
  });

  // Paper color chips
  const paperColors = document.getElementById('paperColors');
  paperColors.querySelectorAll('.chip').forEach(ch=>{
    ch.addEventListener('click', ()=>{
      paperColors.querySelectorAll('.chip').forEach(x=>x.classList.remove('active'));
      ch.classList.add('active');
      state.paperColor = ch.dataset.paper;
      applyPaperColor();
    });
  });

  // Paper type chips
  const paperType = document.getElementById('paperType');
  paperType.querySelectorAll('.chip').forEach(ch=>{
    ch.addEventListener('click', ()=>{
      paperType.querySelectorAll('.chip').forEach(x=>x.classList.remove('active'));
      ch.classList.add('active');
      setPaperType(ch.dataset.type);
    });
  });

  // Brush tip
  const brushType = document.getElementById('brushType');
  brushType.addEventListener('change', e=>{
    state.brushTip = e.target.value;
  });

  // Drawing helpers
  function setStrokeStyle() {
    ctx.globalAlpha = state.opacity;
    ctx.lineWidth = state.size * (state.tool==='marker' ? 1.4 : state.tool==='pencil' ? 0.7 : 1);
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.strokeStyle = state.tool === 'eraser' ? state.paperColor : state.color;
    ctx.fillStyle = ctx.strokeStyle;

    if (state.tool === 'airbrush'){
      // airbrush uses separate logic; nothing here
    } else {
      // set brush by composite or shadow
      if (state.brushTip === 'soft' || state.tool==='airbrush'){
        ctx.shadowColor = ctx.strokeStyle;
        ctx.shadowBlur = state.size * 0.6;
      } else {
        ctx.shadowBlur = 0;
      }
    }
  }

  function drawBrushLine(from, to){
    setStrokeStyle();
    // special textured/ calligraphy tips
    if (state.brushTip === 'square'){
      // draw with square cap by drawing a polygon along the path
      ctx.save();
      ctx.lineCap = 'butt';
      ctx.beginPath();
      ctx.moveTo(from.x, from.y);
      ctx.lineTo(to.x, to.y);
      ctx.stroke();
      ctx.restore();
    } else if (state.brushTip === 'calligraphy'){
      // angled rectangle stamp along path
      const angle = Math.atan2(to.y - from.y, to.x - from.x) + Math.PI/6;
      const step = Math.max(1, state.size*0.6);
      const dx = Math.cos(angle) * step;
      const dy = Math.sin(angle) * step;
      const w = state.size * 1.2;
      const h = state.size * 0.35;
      ctx.save();
      setStrokeStyle();
      ctx.shadowBlur = 0;
      ctx.translate(from.x, from.y);
      const length = Math.hypot(to.x-from.x, to.y-from.y);
      const count = Math.ceil(length/step);
      for(let i=0;i<count;i++){
        const px = dx*i;
        const py = dy*i;
        ctx.save();
        ctx.translate(px, py);
        ctx.rotate(angle);
        ctx.fillRect(-w/2, -h/2, w, h);
        ctx.restore();
      }
      ctx.restore();
    } else if (state.brushTip === 'texture'){
      // dotted texture along path
      const length = Math.hypot(to.x-from.x, to.y-from.y);
      const step = Math.max(1, state.size*0.5);
      const vx = (to.x - from.x)/length;
      const vy = (to.y - from.y)/length;
      ctx.save();
      setStrokeStyle();
      ctx.shadowBlur = 0;
      for(let d=0; d<=length; d+=step){
        const px = from.x + vx*d + (Math.random()-0.5)*state.size*0.2;
        const py = from.y + vy*d + (Math.random()-0.5)*state.size*0.2;
        const r = Math.max(0.5, state.size*0.35 + (Math.random()-0.5)*state.size*0.2);
        ctx.beginPath();
        ctx.arc(px, py, r, 0, Math.PI*2);
        ctx.fill();
      }
      ctx.restore();
    } else if (state.tool === 'pencil'){
      // slightly noisy pencil line
      ctx.save();
      ctx.globalAlpha = state.opacity*0.9;
      ctx.beginPath();
      const wobble = state.size*0.25;
      ctx.moveTo(from.x + (Math.random()-0.5)*wobble, from.y + (Math.random()-0.5)*wobble);
      ctx.lineTo(to.x + (Math.random()-0.5)*wobble, to.y + (Math.random()-0.5)*wobble);
      ctx.stroke();
      ctx.restore();
    } else if (state.tool === 'marker'){
      // thick marker with more opacity layering
      ctx.save();
      ctx.globalAlpha = Math.min(1, state.opacity*0.85);
      ctx.beginPath();
      ctx.moveTo(from.x, from.y);
      ctx.lineTo(to.x, to.y);
      ctx.stroke();
      // second pass for overlap feel
      ctx.globalAlpha = Math.min(1, state.opacity*0.4);
      ctx.beginPath();
      ctx.moveTo(from.x, from.y+0.6);
      ctx.lineTo(to.x, to.y+0.6);
      ctx.stroke();
      ctx.restore();
    } else if (state.tool === 'airbrush'){
      // spray dots between points
      airbrushSpray(to);
    } else {
      // normal round brush
      ctx.beginPath();
      ctx.moveTo(from.x, from.y);
      ctx.lineTo(to.x, to.y);
      ctx.stroke();
    }
  }

  function airbrushSpray(point){
    setStrokeStyle();
    ctx.save();
    const density = Math.max(10, state.size * 2.2);
    const r = state.size * 0.8;
    ctx.globalAlpha = Math.min(1, state.opacity*0.35);
    for (let i=0;i<density;i++){
      const a = Math.random()*Math.PI*2;
      const rr = Math.random()*r;
      const x = point.x + Math.cos(a)*rr;
      const y = point.y + Math.sin(a)*rr;
      const d = Math.max(0.4, state.size*0.08*Math.random());
      ctx.beginPath();
      ctx.arc(x, y, d, 0, Math.PI*2);
      ctx.fillStyle = state.tool === 'eraser' ? state.paperColor : state.color;
      ctx.fill();
    }
    ctx.restore();
  }

  // Shape tools preview
  let previewCanvas = document.createElement('canvas');
  let pctx = previewCanvas.getContext('2d');
  function ensurePreviewSize(){
    previewCanvas.width = canvas.width;
    previewCanvas.height = canvas.height;
  }
  ensurePreviewSize();

  function getPos(e){
    const rect = canvas.getBoundingClientRect();
    const ratio = (window.devicePixelRatio || 1);
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    return {
      x: (clientX - rect.left) * ratio,
      y: (clientY - rect.top) * ratio
    };
  }

  function startDraw(e){
    e.preventDefault();
    pushHistory();
    state.isDrawing = true;
    state.start = state.last = getPos(e);
    if (state.tool === 'fill'){
      floodFill(state.start.x, state.start.y, hexToRgba(state.color, state.opacity));
      state.isDrawing = false;
      return;
    }
    if (['line','rect','circle'].includes(state.tool)){
      ensurePreviewSize();
    } else if (state.tool === 'airbrush'){
      airbrushInterval = setInterval(()=> airbrushSpray(state.last), 35);
    } else {
      // draw a dot for single click
      setStrokeStyle();
      if (state.tool==='eraser'){
        ctx.save();
        ctx.globalCompositeOperation = 'source-over';
        ctx.fillStyle = state.paperColor;
        ctx.beginPath();
        ctx.arc(state.start.x, state.start.y, state.size/2, 0, Math.PI*2);
        ctx.fill();
        ctx.restore();
      } else {
        ctx.beginPath();
        ctx.arc(state.start.x, state.start.y, Math.max(0.5, state.size/2), 0, Math.PI*2);
        ctx.fillStyle = state.color;
        ctx.globalAlpha = state.opacity;
        ctx.fill();
      }
    }
  }

  let airbrushInterval = null;

  function moveDraw(e){
    if (!state.isDrawing) return;
    const pos = getPos(e);
    state.isShift = e.shiftKey;

    if (['line','rect','circle'].includes(state.tool)){
      // live preview: draw on top using XOR-like effect
      ctx.putImageData(state.history[state.history.length-1], 0, 0);
      drawShape(state.start, pos, true);
      return;
    }

    // freehand tools
    if (state.isShift && state.tool!=='airbrush'){
      // straight line hold Shift
      ctx.putImageData(state.history[state.history.length-1], 0, 0);
      drawBrushLine(state.start, pos);
      return;
    }

    drawBrushLine(state.last, pos);
    state.last = pos;
  }

  function endDraw(){
    if (!state.isDrawing) return;
    state.isDrawing = false;
    if (airbrushInterval) { clearInterval(airbrushInterval); airbrushInterval = null; }
    if (['line','rect','circle'].includes(state.tool)){
      // finalize shape
      // The preview already sits on current canvas due to putImageData+draw
    }
  }

  function drawShape(a, b, preview=false){
    setStrokeStyle();
    ctx.globalAlpha = state.opacity;
    ctx.lineWidth = state.size;
    ctx.strokeStyle = state.tool==='eraser' ? state.paperColor : state.color;
    ctx.fillStyle = ctx.strokeStyle;

    if (state.tool==='line'){
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.stroke();
    } else if (state.tool==='rect'){
      const x = Math.min(a.x, b.x);
      const y = Math.min(a.y, b.y);
      const w = Math.abs(a.x - b.x);
      const h = Math.abs(a.y - b.y);
      if (state.brushTip==='soft'){
        ctx.save(); ctx.shadowColor = ctx.strokeStyle; ctx.shadowBlur = state.size*0.6;
        ctx.strokeRect(x, y, w, h);
        ctx.restore();
      } else {
        ctx.strokeRect(x, y, w, h);
      }
    } else if (state.tool==='circle'){
      const rx = (b.x - a.x);
      const ry = (b.y - a.y);
      const r = Math.hypot(rx, ry);
      ctx.beginPath();
      ctx.arc(a.x, a.y, r, 0, Math.PI*2);
      ctx.stroke();
    }
  }

  // Fill tool (simple flood fill)
  function floodFill(x, y, fillColor){
    const img = ctx.getImageData(0,0,canvas.width,canvas.height);
    const data = img.data;
    const w = img.width, h = img.height;
    const startPos = (Math.floor(y)*w + Math.floor(x)) * 4;
    const target = [data[startPos], data[startPos+1], data[startPos+2], data[startPos+3]];
    const match = (i)=> data[i]===target[0] && data[i+1]===target[1] && data[i+2]===target[2] && data[i+3]===target[3];
    const sameAsFill = (i)=> data[i]===fillColor[0] && data[i+1]===fillColor[1] && data[i+2]===fillColor[2] && data[i+3]===fillColor[3];
    if (sameAsFill(startPos)) return;

    const stack = [[Math.floor(x), Math.floor(y)]];
    while(stack.length){
      const [cx, cy] = stack.pop();
      let nx = cx;
      let i = (cy*w + nx)*4;
      // move left
      while(nx>=0 && match(i)){ nx--; i-=4; }
      nx++; i+=4;
      let spanUp=false, spanDown=false;
      // move right, fill, and add neighbors
      while(nx<w && match(i)){
        data[i] = fillColor[0];
        data[i+1] = fillColor[1];
        data[i+2] = fillColor[2];
        data[i+3] = fillColor[3];
        if (cy>0){
          const up = ((cy-1)*w + nx)*4;
          if (match(up) && !spanUp){ stack.push([nx, cy-1]); spanUp=true; }
          else if (!match(up)){ spanUp=false; }
        }
        if (cy<h-1){
          const down = ((cy+1)*w + nx)*4;
          if (match(down) && !spanDown){ stack.push([nx, cy+1]); spanDown=true; }
          else if (!match(down)){ spanDown=false; }
        }
        nx++; i+=4;
      }
    }
    ctx.putImageData(img, 0, 0);
  }

  function hexToRgba(hex, alpha=1){
    const h = hex.replace('#','');
    const bigint = parseInt(h,16);
    const r = (h.length===3) ? ((bigint>>8)&0xF)*17 : (bigint>>16)&255;
    const g = (h.length===3) ? ((bigint>>4)&0xF)*17 : (bigint>>8)&255;
    const b = (h.length===3) ? (bigint&0xF)*17 : (bigint)&255;
    return [r,g,b, Math.floor(alpha*255)];
  }

  // Input events
  canvas.addEventListener('mousedown', startDraw);
  canvas.addEventListener('mousemove', moveDraw);
  window.addEventListener('mouseup', endDraw);

  canvas.addEventListener('touchstart', startDraw, {passive:false});
  canvas.addEventListener('touchmove', moveDraw, {passive:false});
  canvas.addEventListener('touchend', endDraw);

  // Keyboard (Shift for line aid)
  window.addEventListener('keydown', (e)=>{ if(e.key==='Shift') state.isShift=true; });
  window.addEventListener('keyup', (e)=>{ if(e.key==='Shift') state.isShift=false; });

  // Init defaults
  applyPaperColor();
  setPaperType('canvas');

  // Short help for students (simple English + Japanese)
  // How to use:
  // 1) Choose tool (Brush, Pencil, Marker, Air, Eraser, Line, Rectangle, Circle, Fill)
  // 2) Choose color and size (左で色とサイズ)
  // 3) Choose paper color and type (紙の色と種類)
  // 4) Draw on the right (右で描く)
  // 5) Undo, Clear, Save as you like
</script>
</body>
</html>
